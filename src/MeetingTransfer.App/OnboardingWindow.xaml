<Window x:Class="MeetingTransfer.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MeetingTransfer.App"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Welcome to Meeting Transfer"
        Width="920"
        Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{StaticResource WindowBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="GuideCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="StepNumber" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ModelRail" TargetType="Border" BasedOn="{StaticResource GuideCard}">
            <Setter Property="Padding" Value="15,13" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Border Width="22" Height="22" CornerRadius="6" Background="{StaticResource InkBrush}">
                        <TextBlock Text="M" Foreground="#111113" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Meeting Transfer" FontWeight="SemiBold" FontSize="13" Margin="9,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text="  /  FIRST RUN" Foreground="{StaticResource SubtleBrush}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource IconButton}"
                        Content="&#xE8BB;"
                        ToolTip="跳过引导"
                        AutomationProperties.Name="跳过新手引导"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="Skip_Click"
                        Margin="0,0,2,0" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="24,28,22,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="LOCAL-FIRST" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="把会议留在本机"
                                   FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
                                   FontSize="25"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,9,0,0" />
                        <TextBlock Text="录音、转写与导出默认只写入你的电脑。"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   LineHeight="19"
                                   TextWrapping="Wrap"
                                   Margin="0,9,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <Grid Margin="0,0,0,17">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="StepBadgeOne" Style="{StaticResource StepNumber}">
                                <TextBlock Text="01" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="StepLabelOne" Text="开始之前" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Text="本地与隐私" Foreground="{StaticResource SubtleBrush}" FontSize="10" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,17">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="StepBadgeTwo" Style="{StaticResource StepNumber}">
                                <TextBlock Text="02" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="StepLabelTwo" Text="准备模型" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="按用途下载" Foreground="{StaticResource SubtleBrush}" FontSize="10" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="StepBadgeThree" Style="{StaticResource StepNumber}">
                                <TextBlock Text="03" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="StepLabelThree" Text="选择工作流" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="实时或离线" Foreground="{StaticResource SubtleBrush}" FontSize="10" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="2" Background="{StaticResource AccentSurfaceBrush}" BorderBrush="#29466F" BorderThickness="1" CornerRadius="7" Padding="11">
                        <TextBlock Text="发布包不包含模型。只有你主动下载模型时，应用才会连接上游。"
                                   Foreground="#AFCFFF"
                                   FontSize="10"
                                   LineHeight="16"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="34,28,34,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="StepOne" AutomationProperties.Name="新手引导第一步：开始之前">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="WELCOME · 欢迎" Style="{StaticResource EyebrowText}" />
                        <TextBlock Text="三分钟，准备好第一次转写"
                                   FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
                                   FontSize="31"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Meeting Transfer 有两条独立工作流：实时录音与离线导入。你只需要下载自己会用到的模型。"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   LineHeight="21"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,24" />
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource GuideCard}">
                                <StackPanel>
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource SuccessBrush}" FontSize="19" />
                                    <TextBlock Text="本地保存" FontSize="14" FontWeight="SemiBold" Margin="0,12,0,0" />
                                    <TextBlock Text="数据库、录音和导出默认位于程序目录旁；会议内容不会自动上传。"
                                               Foreground="{StaticResource MutedBrush}" FontSize="11" LineHeight="18" TextWrapping="Wrap" Margin="0,7,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource GuideCard}">
                                <StackPanel>
                                    <TextBlock Text="&#xE8D4;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource AccentBrush}" FontSize="19" />
                                    <TextBlock Text="按需下载" FontSize="14" FontWeight="SemiBold" Margin="0,12,0,0" />
                                    <TextBlock Text="正式包只提供运行时。首次使用需在设置中下载相应模型，不会占用不必要的空间。"
                                               Foreground="{StaticResource MutedBrush}" FontSize="11" LineHeight="18" TextWrapping="Wrap" Margin="0,7,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid x:Name="StepTwo" Visibility="Collapsed" AutomationProperties.Name="新手引导第二步：选择并下载模型">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="MODEL SETUP · 模型安装" Style="{StaticResource EyebrowText}" />
                        <TextBlock Text="现在选择并下载你需要的模型"
                                   FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Margin="0,7,0,0" />
                        <TextBlock Text="离线模型下载后会自动设为默认；实时与说话人模型可按需安装。"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   Margin="0,6,0,12" />
                    </StackPanel>

                    <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9">
                        <ListBox x:Name="OnboardingModelsList"
                                 ItemsSource="{Binding CardsView}"
                                 Padding="7"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VirtualizingPanel.IsVirtualizingWhenGrouping="True">
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,10,8,4">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource AccentBrush}" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <Border Grid.Column="1" Height="1" Background="{StaticResource LineBrush}" Margin="9,0,0,0" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,6">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" Margin="0,0,8,0" />
                                            <WrapPanel Margin="0,4,0,0">
                                                <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource LineStrongBrush}" BorderThickness="1" CornerRadius="3" Padding="5,1" Margin="0,0,5,0">
                                                    <TextBlock Text="{Binding Family}" Foreground="{StaticResource MutedBrush}" FontSize="9" />
                                                </Border>
                                                <Border Background="{StaticResource AccentSurfaceBrush}" BorderBrush="#29466F" BorderThickness="1" CornerRadius="3" Padding="5,1">
                                                    <TextBlock Text="{Binding EngineLabel}" Foreground="{StaticResource AccentBrush}" FontSize="9" />
                                                </Border>
                                            </WrapPanel>
                                            <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,4,0,0">
                                                <Run Text="{Binding SizeDisplay, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding LanguagesDisplay, Mode=OneWay}" />
                                            </TextBlock>
                                            <ProgressBar Minimum="0" Maximum="1" Value="{Binding DownloadProgress}" Height="3" Margin="0,6,10,0" Visibility="{Binding IsDownloading, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" />
                                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" FontSize="9" Margin="0,4,0,0" TextWrapping="Wrap" Visibility="{Binding StatusMessage, Converter={x:Static local:NullToVisibilityConverter.Instance}}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="{Binding PrimaryActionLabel}"
                                                Command="{Binding DataContext.PrimaryActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                MinWidth="126"
                                                Padding="9,5"
                                                IsEnabled="{Binding CanPrimary}"
                                                VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <TextBlock x:Name="ModelSetupStatus"
                               Grid.Row="2"
                               Text="至少安装一个模型才能继续；也可以跳过引导，稍后再设置。"
                               Foreground="{StaticResource SubtleBrush}"
                               FontSize="10"
                               Margin="2,9,0,0"
                               TextWrapping="Wrap" />
                </Grid>

                <Grid x:Name="StepThree" Visibility="Collapsed" AutomationProperties.Name="新手引导第三步：选择工作流">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="READY · 准备完成" Style="{StaticResource EyebrowText}" />
                        <TextBlock Text="从你的第一场会议开始"
                                   FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,22" />
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource GuideCard}" Padding="17">
                                <StackPanel>
                                    <TextBlock Text="LIVE / 实时" Foreground="{StaticResource SuccessBrush}" FontSize="10" FontWeight="SemiBold" />
                                    <TextBlock Text="选择音频来源 → 开始" FontSize="15" FontWeight="SemiBold" Margin="0,10,0,0" />
                                    <TextBlock Text="可同时采集系统音频与麦克风，停止时自动保存会话。"
                                               Foreground="{StaticResource MutedBrush}" FontSize="11" LineHeight="18" TextWrapping="Wrap" Margin="0,7,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource GuideCard}" Padding="17">
                                <StackPanel>
                                    <TextBlock Text="IMPORT / 离线" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold" />
                                    <TextBlock Text="选择人数 → 导入" FontSize="15" FontWeight="SemiBold" Margin="0,10,0,0" />
                                    <TextBlock Text="支持常见音视频格式；可在完成后重命名或合并说话人。"
                                               Foreground="{StaticResource MutedBrush}" FontSize="11" LineHeight="18" TextWrapping="Wrap" Margin="0,7,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Background="#151F2D" BorderBrush="#29466F" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,15,0,0">
                            <DockPanel>
                                <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource AccentBrush}" FontSize="15" Margin="0,0,10,0" />
                                <TextBlock Text="模型状态已同步到工作台；以后也可以从左下角“设置”继续下载或切换模型。"
                                           Foreground="#B8CBE8" FontSize="11" TextWrapping="Wrap" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="0,18,0,0" Margin="0,18,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="StepCounter" Text="01 / 03" Foreground="{StaticResource AccentBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" FontWeight="SemiBold" />
                            <TextBlock Text="  初次设置" Foreground="{StaticResource SubtleBrush}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="SkipButton" Content="跳过引导" Style="{StaticResource QuietButton}" Click="Skip_Click" AutomationProperties.Name="跳过新手引导" Margin="0,0,6,0" />
                            <Button x:Name="BackButton" Content="上一步" Click="Back_Click" AutomationProperties.Name="返回上一步" Visibility="Collapsed" Margin="0,0,8,0" />
                            <Button x:Name="NextButton" Content="下一步" Style="{StaticResource AccentButton}" Click="Next_Click" AutomationProperties.Name="进入下一步" MinWidth="112" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
