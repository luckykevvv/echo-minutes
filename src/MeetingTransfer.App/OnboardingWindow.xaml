<Window x:Class="MeetingTransfer.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MeetingTransfer.App"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource WelcomeWindowTitle}"
        Width="920"
        Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{StaticResource WindowBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="GuideCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="StepNumber" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ModelRail" TargetType="Border" BasedOn="{StaticResource GuideCard}">
            <Setter Property="Padding" Value="15,13" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Border Width="22" Height="22" CornerRadius="6" Background="{StaticResource InkBrush}">
                        <TextBlock Text="M" Foreground="#111113" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="EchoMinutes" FontWeight="SemiBold" FontSize="13" Margin="9,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text="{DynamicResource FirstRunTitle}" Foreground="{StaticResource SubtleBrush}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <ComboBox x:Name="OnboardingLanguageBox" Width="130" Margin="0,4,4,4" DisplayMemberPath="DisplayName" SelectedValuePath="Code" SelectionChanged="OnboardingLanguageBox_SelectionChanged" />
                    <Button Style="{StaticResource IconButton}" Content="{StaticResource WindowCloseIcon}" ToolTip="{DynamicResource SkipGuide}" Click="Skip_Click" Margin="0,0,2,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="24,28,22,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource OnboardingLocalFirst}" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="{DynamicResource OnboardingHero}"
                                   FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
                                   FontSize="25"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,9,0,0" />
                        <TextBlock Text="{DynamicResource OnboardingHeroHint}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   LineHeight="19"
                                   TextWrapping="Wrap"
                                   Margin="0,9,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <Grid Margin="0,0,0,17">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="StepBadgeOne" Style="{StaticResource StepNumber}">
                                <TextBlock Text="01" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="StepLabelOne" Text="{DynamicResource StepOneLabel}" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Text="{DynamicResource StepOneHint}" Foreground="{StaticResource SubtleBrush}" FontSize="10" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,17">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="StepBadgeTwo" Style="{StaticResource StepNumber}">
                                <TextBlock Text="02" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="StepLabelTwo" Text="{DynamicResource StepTwoLabel}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{DynamicResource StepTwoHint}" Foreground="{StaticResource SubtleBrush}" FontSize="10" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="StepBadgeThree" Style="{StaticResource StepNumber}">
                                <TextBlock Text="03" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="StepLabelThree" Text="{DynamicResource StepThreeLabel}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{DynamicResource StepThreeHint}" Foreground="{StaticResource SubtleBrush}" FontSize="10" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="2" Background="{StaticResource AccentSurfaceBrush}" BorderBrush="#29466F" BorderThickness="1" CornerRadius="7" Padding="11">
                        <TextBlock Text="{DynamicResource NoBundledModelsHint}"
                                   Foreground="#AFCFFF"
                                   FontSize="10"
                                   LineHeight="16"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="34,28,34,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="StepOne" AutomationProperties.Name="新手引导第一步：开始之前">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource WelcomeEyebrow}" Style="{StaticResource EyebrowText}" />
                        <TextBlock Text="{DynamicResource WelcomeTitle}"
                                   FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
                                   FontSize="31"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="{DynamicResource WelcomeDescription}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   LineHeight="21"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,24" />
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource GuideCard}">
                                <StackPanel>
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource SuccessBrush}" FontSize="19" />
                                <TextBlock Text="{DynamicResource LocalStorageTitle}" FontSize="14" FontWeight="SemiBold" Margin="0,12,0,0" />
                                <TextBlock Text="{DynamicResource LocalStorageDescription}"
                                               Foreground="{StaticResource MutedBrush}" FontSize="11" LineHeight="18" TextWrapping="Wrap" Margin="0,7,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource GuideCard}">
                                <StackPanel>
                                    <TextBlock Text="&#xE8D4;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource AccentBrush}" FontSize="19" />
                                <TextBlock Text="{DynamicResource DownloadOnDemandTitle}" FontSize="14" FontWeight="SemiBold" Margin="0,12,0,0" />
                                <TextBlock Text="{DynamicResource DownloadOnDemandDescription}"
                                               Foreground="{StaticResource MutedBrush}" FontSize="11" LineHeight="18" TextWrapping="Wrap" Margin="0,7,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid x:Name="StepTwo" Visibility="Collapsed" AutomationProperties.Name="新手引导第二步：选择并下载模型">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource ModelSetupEyebrow}" Style="{StaticResource EyebrowText}" />
                        <TextBlock Text="{DynamicResource ModelSetupTitle}"
                                   FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Margin="0,7,0,0" />
                        <TextBlock Text="{DynamicResource ModelSetupDescription}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   Margin="0,6,0,12" />
                    </StackPanel>

                    <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9">
                        <ListBox x:Name="OnboardingModelsList"
                                 ItemsSource="{Binding CardsView}"
                                 Padding="7"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VirtualizingPanel.IsVirtualizingWhenGrouping="True">
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,10,8,4">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource AccentBrush}" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <Border Grid.Column="1" Height="1" Background="{StaticResource LineBrush}" Margin="9,0,0,0" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,6">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" Margin="0,0,8,0" />
                                            <WrapPanel Margin="0,4,0,0">
                                                <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource LineStrongBrush}" BorderThickness="1" CornerRadius="3" Padding="5,1" Margin="0,0,5,0">
                                                    <TextBlock Text="{Binding Family}" Foreground="{StaticResource MutedBrush}" FontSize="9" />
                                                </Border>
                                                <Border Background="{StaticResource AccentSurfaceBrush}" BorderBrush="#29466F" BorderThickness="1" CornerRadius="3" Padding="5,1">
                                                    <TextBlock Text="{Binding EngineLabel}" Foreground="{StaticResource AccentBrush}" FontSize="9" />
                                                </Border>
                                            </WrapPanel>
                                            <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,4,0,0">
                                                <Run Text="{Binding SizeDisplay, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding LanguagesDisplay, Mode=OneWay}" />
                                            </TextBlock>
                                            <ProgressBar Minimum="0" Maximum="1" Value="{Binding DownloadProgress}" Height="3" Margin="0,6,10,0" Visibility="{Binding IsDownloading, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" />
                                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" FontSize="9" Margin="0,4,0,0" TextWrapping="Wrap" Visibility="{Binding StatusMessage, Converter={x:Static local:NullToVisibilityConverter.Instance}}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="{Binding PrimaryActionLabel}"
                                                Command="{Binding DataContext.PrimaryActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                MinWidth="126"
                                                Padding="9,5"
                                                IsEnabled="{Binding CanPrimary}"
                                                VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <TextBlock x:Name="ModelSetupStatus"
                               Grid.Row="2"
                                   Text="{DynamicResource ModelRequiredHint}"
                               Foreground="{StaticResource SubtleBrush}"
                               FontSize="10"
                               Margin="2,9,0,0"
                               TextWrapping="Wrap" />
                </Grid>

                <Grid x:Name="StepThree" Visibility="Collapsed" AutomationProperties.Name="新手引导第三步：选择工作流">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource ReadyEyebrow}" Style="{StaticResource EyebrowText}" />
                        <TextBlock Text="{DynamicResource ReadyTitle}"
                                   FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,22" />
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource GuideCard}" Padding="17">
                                <StackPanel>
                                <TextBlock Text="{DynamicResource LiveWorkflow}" Foreground="{StaticResource SuccessBrush}" FontSize="10" FontWeight="SemiBold" />
                                <TextBlock Text="{DynamicResource LiveWorkflowTitle}" FontSize="15" FontWeight="SemiBold" Margin="0,10,0,0" />
                                <TextBlock Text="{DynamicResource LiveWorkflowDescription}"
                                               Foreground="{StaticResource MutedBrush}" FontSize="11" LineHeight="18" TextWrapping="Wrap" Margin="0,7,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource GuideCard}" Padding="17">
                                <StackPanel>
                                <TextBlock Text="{DynamicResource ImportWorkflow}" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold" />
                                <TextBlock Text="{DynamicResource ImportWorkflowTitle}" FontSize="15" FontWeight="SemiBold" Margin="0,10,0,0" />
                                <TextBlock Text="{DynamicResource ImportWorkflowDescription}"
                                               Foreground="{StaticResource MutedBrush}" FontSize="11" LineHeight="18" TextWrapping="Wrap" Margin="0,7,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Background="#151F2D" BorderBrush="#29466F" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,15,0,0">
                            <DockPanel>
                                <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource AccentBrush}" FontSize="15" Margin="0,0,10,0" />
                            <TextBlock Text="{DynamicResource ModelStateSyncedHint}"
                                           Foreground="#B8CBE8" FontSize="11" TextWrapping="Wrap" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="0,18,0,0" Margin="0,18,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="StepCounter" Text="01 / 03" Foreground="{StaticResource AccentBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="{DynamicResource InitialSetup}" Foreground="{StaticResource SubtleBrush}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="SkipButton" Content="{DynamicResource SkipGuide}" Style="{StaticResource QuietButton}" Click="Skip_Click" Margin="0,0,6,0" />
                            <Button x:Name="BackButton" Content="{DynamicResource PreviousStep}" Click="Back_Click" Visibility="Collapsed" Margin="0,0,8,0" />
                            <Button x:Name="NextButton" Content="{DynamicResource NextStep}" Style="{StaticResource AccentButton}" Click="Next_Click" MinWidth="112" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
