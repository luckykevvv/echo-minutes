<Window x:Class="MeetingTransfer.App.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EchoMinutes update"
        Width="620" Height="520"
        MinWidth="540" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None">
    <Border Background="{StaticResource WindowBrush}" BorderBrush="{StaticResource LineStrongBrush}" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                <Grid>
                    <TextBlock Text="EchoMinutes  /  UPDATE" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0" />
                    <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}" Content="&#xE8BB;" Click="Later_Click" Margin="0,0,2,0" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="30,26,30,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="UPDATE AVAILABLE" Style="{StaticResource EyebrowText}" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock x:Name="ReleaseTitleText" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="28" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap" />
                    <TextBlock x:Name="VersionText" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,7,0,0" />
                </StackPanel>

                <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Margin="0,22,0,20" Padding="17">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="WHAT'S NEW" Style="{StaticResource EyebrowText}" />
                        <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ReleaseNotesText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" LineHeight="20" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="1" Height="4" Visibility="Collapsed" />
                    <TextBlock x:Name="StatusText" Grid.Row="1" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,10,230,0" TextWrapping="Wrap" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="LaterButton" Content="Later" Width="92" Style="{StaticResource QuietButton}" Click="Later_Click" Margin="0,0,8,0" />
                        <Button x:Name="InstallButton" Content="Download and update" Width="170" Style="{StaticResource AccentButton}" Click="Install_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
