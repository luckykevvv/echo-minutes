<UserControl x:Class="MeetingTransfer.App.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MeetingTransfer.App"
             Background="{StaticResource WindowBrush}">

    <UserControl.Resources>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="2"
                                    Margin="0,0,0,18">
                                <TabPanel IsItemsHost="True" />
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabChrome"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="28,22,28,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="2,0,0,18">
                <StackPanel>
                    <TextBlock Text="{DynamicResource SettingsTitle}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="26" FontWeight="SemiBold" />
                    <TextBlock x:Name="SettingsPathText" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Button x:Name="BackToWorkspaceButton"
                        Content="{DynamicResource BackWorkspace}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Style="{StaticResource QuietButton}"
                        Padding="12,7"
                        Click="Back_Click" />
            </Grid>

            <TabControl Grid.Row="1">
                <TabItem Header="{DynamicResource GeneralTab}">
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="9" Padding="24" MaxWidth="720" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="190" /><ColumnDefinition Width="360" /></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="{DynamicResource AppLanguage}" FontWeight="SemiBold" />
                                <TextBlock Text="{DynamicResource AppLanguageHint}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,5,18,0" />
                            </StackPanel>
                            <ComboBox x:Name="ApplicationLanguageBox" Grid.Row="0" Grid.Column="1" DisplayMemberPath="DisplayName" SelectedValuePath="Code" SelectionChanged="ApplicationLanguageBox_SelectionChanged" />
                            <StackPanel Grid.Row="1" Margin="0,22,18,0">
                                <TextBlock Text="{DynamicResource RecordingRefinement}" FontWeight="SemiBold" />
                                <TextBlock Text="{DynamicResource RecordingRefinementHint}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="RefineRecordingOnStopBox"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Content="{DynamicResource RecordingRefinementToggle}"
                                      VerticalAlignment="Top"
                                      Margin="0,24,0,0" />
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem Header="{DynamicResource ModelsTab}">
                    <Grid Background="{StaticResource SurfaceBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="470" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="350" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="8,8,0,0" Padding="16,13">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource ModelLibrary}" Style="{StaticResource EyebrowText}" />
                                        <TextBlock Text="{DynamicResource ModelLibraryHint}" Foreground="{StaticResource SubtleBrush}" FontSize="11" HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                                <Separator Grid.Row="0" VerticalAlignment="Bottom" />
                                <ListBox x:Name="ModelsList"
                                         Grid.Row="1"
                                         ItemsSource="{Binding CardsView}"
                                         Background="{StaticResource SurfaceBrush}"
                                         Padding="0"
                                         VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                         SelectionChanged="ModelsList_SelectionChanged">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="ItemChrome"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#284A78" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.ContainerStyle>
                                                <Style TargetType="GroupItem">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="GroupItem">
                                                                <StackPanel Background="{StaticResource SurfaceBrush}">
                                                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                                      ContentStringFormat="{TemplateBinding ContentStringFormat}" />
                                                                    <ItemsPresenter Margin="0" />
                                                                </StackPanel>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </GroupStyle.ContainerStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="14,14,14,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                            <Border Grid.Column="1" Height="1" Background="{StaticResource LineBrush}" Margin="12,0,0,0" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ListBox.GroupStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="14,11">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" Margin="0,0,8,0" />
                                                    <WrapPanel Margin="0,6,0,0">
                                                        <Border Style="{StaticResource Badge}">
                                                            <TextBlock Text="{Binding Family}" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                                        </Border>
                                                        <Border Style="{StaticResource Badge}">
                                                            <TextBlock Text="{Binding EngineLabel}" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold" />
                                                        </Border>
                                                        <Border Style="{StaticResource Badge}" Visibility="{Binding IsGpuBackend, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" Background="#152B20" BorderBrush="#28513B">
                                                            <TextBlock Text="GPU" Foreground="{StaticResource SuccessBrush}" FontSize="10" FontWeight="SemiBold" />
                                                        </Border>
                                                        <Border Style="{StaticResource Badge}" Visibility="{Binding IsCpuBackend, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" Background="#2A2118" BorderBrush="#4D3926">
                                                            <TextBlock Text="CPU" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="SemiBold" />
                                                        </Border>
                                                    </WrapPanel>
                                                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" FontSize="11">
                                                        <Run Text="{Binding SizeDisplay, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding LanguagesDisplay, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding ExecutionMode, Mode=OneWay}" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap" Visibility="{Binding StatusMessage, Converter={x:Static local:NullToVisibilityConverter.Instance}}" />
                                                    <ProgressBar Minimum="0" Maximum="1" Value="{Binding DownloadProgress}" Margin="0,7,0,0" Visibility="{Binding IsDownloading, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                                    <Button Content="{Binding PrimaryActionLabel}" Command="{Binding DataContext.PrimaryActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" MinWidth="132" IsEnabled="{Binding CanPrimary}" />
                                                    <Button Content="{DynamicResource DeleteLabel}" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" MinWidth="132" Margin="0,5,0,0" Visibility="{Binding CanDelete, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" />

                        <Border Grid.Column="2" Background="{StaticResource SurfaceRaisedBrush}" BorderThickness="0" CornerRadius="9" Padding="19">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          Padding="0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ModelDetails}" Style="{StaticResource EyebrowText}" />
                                    <TextBlock Text="{Binding SelectedCard.DisplayName}" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="21" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,9,0,0" />
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Border Style="{StaticResource Badge}"><TextBlock Text="{Binding SelectedCard.Family}" Foreground="{StaticResource MutedBrush}" FontSize="10" /></Border>
                                        <Border Style="{StaticResource Badge}"><TextBlock Text="{Binding SelectedCard.EngineLabel}" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold" /></Border>
                                        <Border Style="{StaticResource Badge}" Visibility="{Binding SelectedCard.IsGpuBackend, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" Background="#152B20" BorderBrush="#28513B"><TextBlock Text="GPU" Foreground="{StaticResource SuccessBrush}" FontSize="10" /></Border>
                                        <Border Style="{StaticResource Badge}" Visibility="{Binding SelectedCard.IsCpuBackend, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" Background="#2A2118" BorderBrush="#4D3926"><TextBlock Text="CPU" Foreground="{StaticResource WarningBrush}" FontSize="10" /></Border>
                                    </StackPanel>
                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="{DynamicResource SizeLabel}" Style="{StaticResource EyebrowText}" /><TextBlock Text="{Binding SelectedCard.SizeDisplay}" Margin="0,5,0,0" /></StackPanel>
                                        <StackPanel Grid.Column="1"><TextBlock Text="{DynamicResource ModeLabel}" Style="{StaticResource EyebrowText}" /><TextBlock Text="{Binding SelectedCard.ExecutionMode}" Margin="0,5,0,0" /></StackPanel>
                                    </Grid>
                                    <Separator Margin="0,18,0,16" />
                                    <TextBlock Text="{DynamicResource DescriptionLabel}" Style="{StaticResource EyebrowText}" />
                                    <TextBlock Text="{Binding SelectedCard.Description}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" LineHeight="19" Margin="0,7,0,0" />
                                    <TextBlock Text="{DynamicResource SpeedLabel}" Style="{StaticResource EyebrowText}" Margin="0,18,0,0" />
                                    <TextBlock Text="{Binding SelectedCard.SpeedNote}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" LineHeight="19" Margin="0,7,0,0" />
                                    <TextBlock Text="{DynamicResource AccuracyLabel}" Style="{StaticResource EyebrowText}" Margin="0,18,0,0" />
                                    <TextBlock Text="{Binding SelectedCard.AccuracyNote}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" LineHeight="19" Margin="0,7,0,0" />
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource ToolsTab}">
                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="20" MaxWidth="840" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="520" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{DynamicResource FfmpegExecutable}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                            <TextBox x:Name="FfmpegPathBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" />
                            <Button Grid.Row="0" Grid.Column="2" Content="{DynamicResource BrowseLabel}" Tag="FfmpegPathBox" Click="BrowseFile_Click" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="1" Text="{DynamicResource RealtimeExecutable}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                            <TextBox x:Name="OnlineExeBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,8" />
                            <Button Grid.Row="1" Grid.Column="2" Content="{DynamicResource BrowseLabel}" Tag="OnlineExeBox" Click="BrowseFile_Click" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="2" Text="{DynamicResource RealtimeArguments}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                            <TextBox x:Name="OnlineArgsBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="3" Text="{DynamicResource OfflineLanguage}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="OfflineLanguageBox" Grid.Row="3" Grid.Column="1" SelectedValuePath="Tag">
                                <ComboBoxItem Content="{DynamicResource OfflineLanguageBilingual}" Tag="bilingual" />
                                <ComboBoxItem Content="{DynamicResource OfflineLanguageChinese}" Tag="zh" />
                                <ComboBoxItem Content="{DynamicResource OfflineLanguageEnglish}" Tag="en" />
                            </ComboBox>
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem Header="{DynamicResource UpdatesTab}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="560" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="24" VerticalAlignment="Top">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource ApplicationUpdates}" Style="{StaticResource EyebrowText}" />
                                        <TextBlock Text="EchoMinutes" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBlock Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0">
                                            <Run Text="{DynamicResource InstalledVersion}" /><Run x:Name="CurrentVersionText" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="48" Height="48" CornerRadius="24" Background="{StaticResource AccentSurfaceBrush}" BorderBrush="#284A78" BorderThickness="1">
                                        <TextBlock Text="↻" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                                <Separator Grid.Row="1" Margin="0,22,0,18" />
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                        <TextBlock x:Name="UpdateStatusText" Text="{DynamicResource AutomaticUpdateHint}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Text="{DynamicResource UpdateSource}" Foreground="{StaticResource SubtleBrush}" FontSize="11" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button x:Name="CheckForUpdatesButton" Grid.Column="1" Content="{DynamicResource CheckForUpdates}" Width="154" Style="{StaticResource AccentButton}" Click="CheckForUpdates_Click" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <DockPanel Grid.Row="2" Margin="0,18,0,0">
                <TextBlock Text="{DynamicResource SettingsStorageHint}" Foreground="{StaticResource SubtleBrush}" FontSize="11" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{DynamicResource CancelLabel}" Width="92" Click="Cancel_Click" Style="{StaticResource QuietButton}" Margin="0,0,8,0" />
                    <Button x:Name="SaveSettingsButton" Content="{DynamicResource SaveLabel}" Width="118" Click="Save_Click" Style="{StaticResource AccentButton}" />
                </StackPanel>
            </DockPanel>
    </Grid>
</UserControl>
