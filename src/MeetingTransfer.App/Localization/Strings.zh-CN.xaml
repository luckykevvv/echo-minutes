  <sys:String x:Key="WelcomeEyebrow" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">欢迎</sys:String>
  <sys:String x:Key="WelcomeDescription" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">EchoMinutes 有两条独立工作流：实时录音与离线导入。你只需要下载自己会用到的模型。</sys:String>
  <sys:String x:Key="LocalStorageTitle" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">本地保存</sys:String>
  <sys:String x:Key="LocalStorageDescription" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">数据库、录音和导出默认位于程序目录旁；会议内容不会自动上传。</sys:String>
  <sys:String x:Key="DownloadOnDemandTitle" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">按需下载</sys:String>
