  <sys:String x:Key="Model.whisper-tiny.en.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Whisper tiny.en（GGML，仅英语）</sys:String>
  <sys:String x:Key="Model.whisper-tiny.en.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">体积最小的 Whisper.cpp 英语专用模型。适合速度优先的英语草稿；在 Windows 上通过内置 Vulkan 运行时支持 AMD、Intel 和 NVIDIA GPU。</sys:String>
  <sys:String x:Key="Model.whisper-tiny.en.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">非常快。GPU（Vulkan）约为实时速度的 32 倍；回退到 CPU 时约慢 8–10 倍。</sys:String>
  <sys:String x:Key="Model.whisper-tiny.en.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Whisper 系列中准确度最低，不适合中文或双语会议。</sys:String>
  <sys:String x:Key="Model.whisper-base.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Whisper base（GGML，多语言）</sys:String>
  <sys:String x:Key="Model.whisper-base.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">小型多语言 Whisper.cpp 模型，适合中文、英语和混合语言草稿；在 Windows 上通过内置 Vulkan 运行时支持 AMD、Intel 和 NVIDIA GPU。</sys:String>
  <sys:String x:Key="Model.whisper-base.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">快。GPU（Vulkan）约为实时速度的 20 倍；回退到 CPU 时约慢 8–10 倍。</sys:String>
  <sys:String x:Key="Model.whisper-base.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">清晰语音下表现尚可，但长会议、噪声、口音和语言切换会降低准确度。</sys:String>
  <sys:String x:Key="Model.whisper-small.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Whisper small（GGML，多语言）</sys:String>
  <sys:String x:Key="Model.whisper-small.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">中型多语言 Whisper.cpp 模型，准确度高于 base，同时远小于 large-v3-turbo；在 Windows 上通过内置 Vulkan 运行时支持 AMD、Intel 和 NVIDIA GPU。</sys:String>
  <sys:String x:Key="Model.whisper-small.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">中等。GPU（Vulkan）约为实时速度的 5 倍；回退到 CPU 时约慢 8–10 倍。</sys:String>
  <sys:String x:Key="Model.whisper-small.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">适合日常中英文音频，但稳定性不及 large-v3-turbo。</sys:String>
  <sys:String x:Key="Model.whisper-large-v3-turbo.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Whisper large-v3 turbo（GGML，Vulkan）</sys:String>
  <sys:String x:Key="Model.whisper-large-v3-turbo.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">推荐用于离线文件转写的 Whisper.cpp 模型。安装后从设置中下载；通过 Vulkan 支持 AMD、Intel 和 NVIDIA GPU，对多语言及中英混说有较强准确度。</sys:String>
  <sys:String x:Key="Model.whisper-large-v3-turbo.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">GPU（Vulkan）处理 5 分钟音频约需 30 秒；回退到 CPU 时约慢 5–10 倍。</sys:String>
  <sys:String x:Key="Model.whisper-large-v3-turbo.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">多语言和中英混合内容准确度优秀，推荐作为 GPU 离线导入的默认模型。</sys:String>
  <sys:String x:Key="Model.sense-voice-small.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">SenseVoice Small（阿里巴巴，多语言）</sys:String>
  <sys:String x:Key="Model.sense-voice-small.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">阿里巴巴 SenseVoice-Small，除文本外还会输出情绪、事件和语言标签。中文及粤语准确度接近 Whisper large-v3，但语言覆盖较少；当前构建仅支持 CPU。</sys:String>
  <sys:String x:Key="Model.sense-voice-small.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">仅 CPU：约为实时速度的 10 倍。GPU 加速需要自行构建支持 DirectML 的 sherpa-onnx。</sys:String>
  <sys:String x:Key="Model.sense-voice-small.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">中文和粤语表现优秀；长篇纯英语内容弱于 Whisper large-v3。</sys:String>
  <sys:String x:Key="Model.paraformer-large-zh.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Paraformer-large（仅中文）</sys:String>
  <sys:String x:Key="Model.paraformer-large-zh.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">阿里巴巴 FunASR Paraformer-large 中文离线模型，内置较强的标点、文本规范化和数字处理；不适合英语或中英混说，当前构建仅支持 CPU。</sys:String>
  <sys:String x:Key="Model.paraformer-large-zh.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">仅 CPU：约为实时速度的 3 倍。GPU 加速需要自行构建支持 DirectML 的 sherpa-onnx。</sys:String>
  <sys:String x:Key="Model.paraformer-large-zh.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">纯中文表现优秀，不适合语言切换或英语内容。</sys:String>
  <sys:String x:Key="Model.streaming-paraformer-bilingual.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Paraformer 流式模型（中英双语，实时）</sys:String>
  <sys:String x:Key="Model.streaming-paraformer-bilingual.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">实时录音必需模型。准确度低于离线 Whisper/SenseVoice，但可每隔数秒生成局部结果供界面实时显示；当前构建仅支持 CPU。</sys:String>
  <sys:String x:Key="Model.streaming-paraformer-bilingual.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">仅 CPU：流式处理，每个音频块延迟低于一秒。</sys:String>
  <sys:String x:Key="Model.streaming-paraformer-bilingual.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">适合实时预览；最终稿建议使用更强的离线模型重新转写。</sys:String>
  <sys:String x:Key="Model.speaker-diarization.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">说话人分离（pyannote + 3D-Speaker）</sys:String>
  <sys:String x:Key="Model.speaker-diarization.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">为导入录音标记“说话人 1、说话人 2”等标签所需的功能模型，包含 pyannote 分段和 3D-Speaker ERes2Net 声纹嵌入模型。</sys:String>
  <sys:String x:Key="Model.speaker-diarization.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">离线转写完成后由 CPU 进行后处理。</sys:String>
  <sys:String x:Key="Model.speaker-diarization.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">根据声纹嵌入聚类说话轮次；快速交接处的文本归属仍可能存在偏差。</sys:String>
</ResourceDictionary>
