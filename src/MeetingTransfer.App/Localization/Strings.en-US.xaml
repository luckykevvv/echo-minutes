  <sys:String x:Key="LiveWorkflowDescription" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Capture system audio and microphone together. The session is saved automatically when recording stops.</sys:String>
  <sys:String x:Key="ImportWorkflow" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">OFFLINE IMPORT</sys:String>
  <sys:String x:Key="ImportWorkflowTitle" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Choose speaker count → Import</sys:String>
