  <sys:String x:Key="LocalStorageDescription" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">The database, recordings, and exports stay beside the app by default. Meeting content is never uploaded automatically.</sys:String>
  <sys:String x:Key="DownloadOnDemandTitle" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Download on demand</sys:String>
