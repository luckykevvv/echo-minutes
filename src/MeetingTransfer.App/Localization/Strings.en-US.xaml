  <sys:String x:Key="Model.whisper-tiny.en.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Whisper tiny.en (GGML, English)</sys:String>
  <sys:String x:Key="Model.whisper-tiny.en.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Smallest English-only whisper.cpp model. Best for quick English drafts when speed matters more than accuracy. Runs through the included Vulkan runtime on AMD, Intel, and NVIDIA GPUs on Windows.</sys:String>
  <sys:String x:Key="Model.whisper-tiny.en.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Very fast. ~32x real-time on GPU (Vulkan). Roughly 8–10x slower on CPU fallback.</sys:String>
  <sys:String x:Key="Model.whisper-tiny.en.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Lowest Whisper accuracy. Not suitable for Chinese or bilingual meetings.</sys:String>
  <sys:String x:Key="Model.whisper-base.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Whisper base (GGML, multilingual)</sys:String>
  <sys:String x:Key="Model.whisper-base.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Small multilingual whisper.cpp model. A compact option for Chinese, English, and mixed-language drafts. Runs through the included Vulkan runtime on AMD, Intel, and NVIDIA GPUs on Windows.</sys:String>
  <sys:String x:Key="Model.whisper-base.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Fast. ~20x real-time on GPU (Vulkan). Roughly 8–10x slower on CPU fallback.</sys:String>
  <sys:String x:Key="Model.whisper-base.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Acceptable for clean speech, but weaker on long meetings, noise, accents, and code-switching.</sys:String>
  <sys:String x:Key="Model.whisper-small.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Whisper small (GGML, multilingual)</sys:String>
  <sys:String x:Key="Model.whisper-small.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Mid-size multilingual whisper.cpp model. Better accuracy than base while remaining much smaller than large-v3-turbo. Runs through the included Vulkan runtime on AMD, Intel, and NVIDIA GPUs on Windows.</sys:String>
  <sys:String x:Key="Model.whisper-small.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Moderate. ~5x real-time on GPU (Vulkan). Roughly 8–10x slower on CPU fallback.</sys:String>
  <sys:String x:Key="Model.whisper-small.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Good for everyday Chinese-English audio, but not as robust as large-v3-turbo.</sys:String>
  <sys:String x:Key="Model.whisper-large-v3-turbo.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Whisper large-v3 turbo (GGML, Vulkan)</sys:String>
  <sys:String x:Key="Model.whisper-large-v3-turbo.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Recommended whisper.cpp model for offline file transcription. Download it from Settings after installation. Runs through Vulkan on AMD, Intel, and NVIDIA GPUs and provides strong multilingual and Chinese-English code-switched accuracy.</sys:String>
  <sys:String x:Key="Model.whisper-large-v3-turbo.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">About 30 seconds for five minutes of audio on GPU (Vulkan). Roughly 5–10x slower on CPU fallback.</sys:String>
  <sys:String x:Key="Model.whisper-large-v3-turbo.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Excellent multilingual accuracy for Chinese-English content. Recommended default for imported meetings on GPU.</sys:String>
  <sys:String x:Key="Model.sense-voice-small.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">SenseVoice Small (Alibaba, multilingual)</sys:String>
  <sys:String x:Key="Model.sense-voice-small.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Alibaba SenseVoice-Small. Outputs emotion, event, and language ID tags in addition to text. Chinese and Cantonese accuracy rivals Whisper large-v3. Language coverage is limited, and this build currently uses CPU only.</sys:String>
  <sys:String x:Key="Model.sense-voice-small.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">CPU only: ~10x real-time. GPU acceleration requires a self-built sherpa-onnx with DirectML.</sys:String>
  <sys:String x:Key="Model.sense-voice-small.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Excellent on Chinese and Cantonese. Weaker on long English-only content than Whisper large-v3.</sys:String>
  <sys:String x:Key="Model.paraformer-large-zh.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Paraformer-large (Chinese only)</sys:String>
  <sys:String x:Key="Model.paraformer-large-zh.Description" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Alibaba FunASR Paraformer-large for Chinese-only offline ASR. Strong punctuation, text normalization, and number handling. Not suitable for English or code-switching; this build currently uses CPU only.</sys:String>
  <sys:String x:Key="Model.paraformer-large-zh.Speed" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">CPU only: ~3x real-time. GPU acceleration requires a self-built sherpa-onnx with DirectML.</sys:String>
  <sys:String x:Key="Model.paraformer-large-zh.Accuracy" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Excellent for pure Chinese. Not suitable for code-switched or English content.</sys:String>
  <sys:String x:Key="Model.streaming-paraformer-bilingual.Name" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">Paraformer streaming (Chinese / English, realtime)</sys:String>
