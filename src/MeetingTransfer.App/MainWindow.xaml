<Window x:Class="MeetingTransfer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MeetingTransfer.App"
        xmlns:updates="clr-namespace:MeetingTransfer.App.Updates"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding AppTitle}"
        MinWidth="1040"
        MinHeight="680"
        Width="1360"
        Height="860"
        WindowStyle="None"
        ResizeMode="CanResize"
        Loaded="MainWindow_Loaded"
        Background="{StaticResource WindowBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Integrated title bar -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="248" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Width="22" Height="22" CornerRadius="6" Background="{StaticResource InkBrush}">
                        <TextBlock Text="M" Foreground="#111113" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{Binding AppTitle}" FontWeight="SemiBold" FontSize="13" Margin="9,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="TitleContextText" Grid.Column="1" Text="{Binding Document.Title}" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" />
                <TextBlock x:Name="SettingsTitleText" Grid.Column="1" Text="{DynamicResource SettingsTitle}" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" />
                <TextBlock x:Name="HistoryTitleText" Grid.Column="1" Text="{DynamicResource SessionHistoryTitle}" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock x:Name="BuildVersionText"
                               Text="{x:Static updates:UpdateCoordinator.CurrentVersionText}"
                               Foreground="{StaticResource SubtleBrush}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <Button x:Name="MinimizeWindowButton" Style="{StaticResource IconButton}" Content="{StaticResource WindowMinimizeIcon}" ToolTip="{DynamicResource WindowMinimizeTooltip}" Click="Minimize_Click" />
                    <Button x:Name="MaximizeWindowButton" Style="{StaticResource IconButton}" Content="{StaticResource WindowMaximizeIcon}" ToolTip="{DynamicResource WindowMaximizeTooltip}" Click="Maximize_Click" />
                    <Button x:Name="CloseWindowButton" Style="{StaticResource IconButton}" Content="{StaticResource WindowCloseIcon}" ToolTip="{DynamicResource WindowCloseTooltip}" Click="Close_Click" Margin="0,0,2,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="WorkspaceView" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248" />
                <ColumnDefinition Width="*" MinWidth="500" />
                <ColumnDefinition Width="292" />
            </Grid.ColumnDefinitions>

            <!-- Left control rail -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="14,16,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Grid Margin="2,0,2,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding WorkbenchLabel}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding EngineStatus}" Style="{StaticResource EyebrowText}" Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="{Binding ToggleLanguageLabel}" Command="{Binding ToggleLanguageCommand}" Style="{StaticResource QuietButton}" Padding="8,3" MinHeight="28" />
                        </Grid>

                        <TextBlock Text="{Binding DevicesLabel}" Style="{StaticResource EyebrowText}" Margin="2,0,0,9" />

                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="11" Margin="0,0,0,8">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="&#xE7F5;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding SystemAudioLabel}" FontWeight="SemiBold" FontSize="12" />
                                </DockPanel>
                                <ComboBox ItemsSource="{Binding SystemAudioSources}" SelectedItem="{Binding SelectedSystemAudioSource}">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" /></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                                <CheckBox Content="{Binding CaptureSystemAudioLabel}" IsChecked="{Binding CaptureSystemAudio}" Margin="1,9,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="11">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="&#xE720;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding MicrophoneLabel}" FontWeight="SemiBold" FontSize="12" />
                                </DockPanel>
                                <ComboBox ItemsSource="{Binding MicrophoneSources}" SelectedItem="{Binding SelectedMicrophoneSource}">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" /></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                                <CheckBox Content="{Binding CaptureMicrophoneLabel}" IsChecked="{Binding CaptureMicrophone}" Margin="1,9,0,0" />
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{Binding StartLabel}" Command="{Binding StartCommand}" Style="{StaticResource AccentButton}" />
                            <Button Grid.Column="2" Content="{Binding StopLabel}" Command="{Binding StopCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding ExpectedSpeakersLabel}" Style="{StaticResource EyebrowText}" Margin="2,15,0,7" />
                        <ComboBox ItemsSource="{Binding SpeakerCountOptions}"
                                  SelectedItem="{Binding SelectedSpeakerCount}"
                                  Margin="0,0,0,8">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <StackPanel>
                            <Button Content="{Binding ImportLabel}" Command="{Binding ImportCommand}" />
                            <Button
                                    Content="{Binding CancelOperationLabel}"
                                    Command="{Binding CancelOperationCommand}"
                                    Style="{StaticResource QuietButton}"
                                    Margin="0,6,0,0"
                                    Visibility="{Binding CanCancelOperation, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="11" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ProgressLabel}" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock Grid.Column="1" Text="{Binding OperationProgress, StringFormat={}{0:0}%}" Foreground="{StaticResource SubtleBrush}" FontSize="11" Margin="12,0,0,0" />
                                </Grid>
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding OperationProgress}" IsIndeterminate="{Binding IsProgressIndeterminate}" Margin="0,9,0,8" />
                                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" FontSize="11" LineHeight="17" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Button Content="{Binding HistoryLabel}" Command="{Binding HistoryCommand}" Style="{StaticResource QuietButton}" HorizontalContentAlignment="Left" Padding="8,7" Margin="0,0,0,4" />
                        <Button Content="{Binding SettingsLabel}" Command="{Binding SettingsCommand}" Style="{StaticResource QuietButton}" HorizontalContentAlignment="Left" Padding="8,7" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Transcript workspace -->
            <Grid Grid.Column="1" Margin="26,22,26,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="4,0,4,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding TranscriptLabel}" Style="{StaticResource EyebrowText}" />
                        <TextBlock Text="{Binding Document.Title}" FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI" FontSize="28" FontWeight="SemiBold" Margin="0,5,0,0" />
                        <TextBlock Text="{Binding SessionSummary}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,5,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Width="190">
                        <Button Content="{Binding ExportLabel}" Command="{Binding ExportCommand}" HorizontalAlignment="Right" MinWidth="94" />
                        <TextBlock Text="{Binding SearchTranscriptLabel}" Style="{StaticResource EyebrowText}" Margin="0,11,0,5" />
                        <TextBox Text="{Binding SegmentSearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10">
                    <ListBox ItemsSource="{Binding SegmentsView}" Padding="10,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,6,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Start, StringFormat={}{0:mm\:ss}}" Foreground="{StaticResource SubtleBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" Margin="0,3,0,0" />
                                    <Border Grid.Column="1" Background="{StaticResource AccentBrush}" CornerRadius="2" Margin="0,1,0,3" Opacity="0.7" />
                                    <StackPanel Grid.Column="2" Margin="14,0,10,13">
                                        <TextBlock Text="{Binding SpeakerName}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding Text, Mode=OneWay}"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 Foreground="{StaticResource InkBrush}"
                                                 FontSize="14"
                                                 Background="Transparent"
                                                 BorderBrush="Transparent"
                                                 BorderThickness="0"
                                                 Padding="0"
                                                 Margin="0,5,0,0"
                                                 LostKeyboardFocus="SegmentTextBox_LostKeyboardFocus"
                                                 KeyDown="SegmentTextBox_KeyDown" />
                                        <TextBlock Text="{Binding DataContext.SegmentEditHint, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Foreground="{StaticResource SubtleBrush}"
                                                   FontSize="10"
                                                   Margin="0,5,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Button Content="{Binding DataContext.MergePreviousLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Command="{Binding DataContext.MergePreviousSegmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource QuietButton}"
                                                    Padding="5,2"
                                                    MinHeight="23"
                                                    FontSize="10" />
                                            <Button Content="{Binding DataContext.DeleteSegmentLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Command="{Binding DataContext.DeleteSegmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource QuietButton}"
                                                    Padding="5,2"
                                                    MinHeight="23"
                                                    FontSize="10"
                                                    Margin="6,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Bottom" Height="1" Background="{StaticResource LineBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <!-- Inspector -->
            <Border Grid.Column="2" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1,0,0,0">
                <Grid Margin="17,20,17,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{Binding SpeakersLabel}" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SpeakersHint}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,12" />
                    </StackPanel>

                    <Grid x:Name="SpeakerInspectorContent" Grid.Row="1">
                        <Border x:Name="NoSpeakersPanel"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="9"
                                Padding="20"
                                VerticalAlignment="Top"
                                Visibility="{Binding HasNoSpeakers, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                            <StackPanel HorizontalAlignment="Center" MaxWidth="210" Margin="0,18,0,18">
                                <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource SurfaceRaisedBrush}" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE716;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource SubtleBrush}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding NoSpeakersTitle}" FontSize="13" FontWeight="SemiBold" TextAlignment="Center" Margin="0,13,0,0" />
                                <TextBlock Text="{Binding NoSpeakersHint}" Foreground="{StaticResource MutedBrush}" FontSize="11" LineHeight="17" TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer x:Name="SpeakersListPanel"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding HasSpeakers, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                            <ItemsControl x:Name="SpeakerItemsControl" ItemsSource="{Binding Speakers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceBrush}"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,0,0,8"
                                                Padding="12,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3" />
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{StaticResource AccentBrush}" CornerRadius="2" Opacity="0.75" Margin="0,2,0,2" />
                                                <Border Grid.Column="1" Width="24" Height="24" CornerRadius="12" Background="{StaticResource AccentSurfaceBrush}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="4,1,0,0">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource AccentBrush}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="2" Margin="9,0,0,0">
                                                    <TextBox Text="{Binding Name, Mode=OneWay}"
                                                             Tag="{Binding Id}"
                                                             FontSize="13"
                                                             FontWeight="SemiBold"
                                                             Background="Transparent"
                                                             BorderBrush="{StaticResource LineStrongBrush}"
                                                             BorderThickness="0,0,0,1"
                                                             Padding="0,2,0,5"
                                                             LostKeyboardFocus="SpeakerNameBox_LostKeyboardFocus"
                                                             KeyDown="SpeakerNameBox_KeyDown"
                                                             AutomationProperties.Name="编辑说话人标签" />
                                                    <Button Content="{Binding DataContext.MergeSpeakerLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Command="{Binding DataContext.MergeSpeakerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            HorizontalAlignment="Left"
                                                            Padding="0,5"
                                                            MinHeight="24"
                                                            FontSize="10"
                                                            Margin="0,3,0,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource QuietButton}">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <StackPanel Grid.Row="2">
                        <Separator Margin="0,0,0,14" />
                        <TextBlock Text="{Binding SessionLabel}" Style="{StaticResource EyebrowText}" />
                        <TextBlock Text="{Binding Document.SessionId}" Foreground="{StaticResource SubtleBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,7,0,0" />
                        <TextBlock Text="{Binding StoragePath}" Foreground="{StaticResource SubtleBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,5,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="SettingsHost"
              Grid.Row="1"
              Background="{StaticResource WindowBrush}"
              Visibility="Collapsed" />
        <Grid x:Name="HistoryHost"
              Grid.Row="1"
              Background="{StaticResource WindowBrush}"
              Visibility="Collapsed" />
    </Grid>
</Window>
