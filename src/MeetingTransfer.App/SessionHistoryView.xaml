<UserControl x:Class="MeetingTransfer.App.SessionHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MeetingTransfer.App"
             Loaded="SessionHistoryView_Loaded"
             Background="{StaticResource WindowBrush}">
    <Grid Margin="32,24,32,26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="2,0,0,22">
            <StackPanel>
                <TextBlock Text="{DynamicResource SessionHistoryTitle}"
                           FontFamily="Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="{DynamicResource SessionHistoryHint}"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           Margin="0,6,0,0" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal">
                <Button Content="{DynamicResource BackWorkspace}"
                        Style="{StaticResource QuietButton}"
                        Padding="12,7"
                        Margin="0,0,8,0"
                        Click="Back_Click" />
                <Button Content="{DynamicResource NewMeetingLabel}"
                        Style="{StaticResource AccentButton}"
                        Padding="16,7"
                        Click="NewMeeting_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="2,0,2,12">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource SubtleBrush}"
                       FontSize="11"
                       VerticalAlignment="Center" />
            <ProgressBar IsIndeterminate="True"
                         Height="2"
                         VerticalAlignment="Bottom"
                         Visibility="{Binding IsLoading, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" />
        </Grid>

        <Grid Grid.Row="2">
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="11"
                    Visibility="{Binding HasSessions, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                <ListBox x:Name="SessionList"
                         ItemsSource="{Binding Sessions}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="10"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="SessionCard"
                                    Background="{StaticResource SurfaceRaisedBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Padding="18,15"
                                    Margin="3,3,3,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="3"
                                            Opacity="0.75"
                                            Margin="0,1,0,1" />
                                    <StackPanel Grid.Column="1" Margin="16,0,24,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Background="{StaticResource AccentSurfaceBrush}"
                                                    BorderBrush="#284A78"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    Margin="10,0,0,0"
                                                    Visibility="{Binding IsCurrent, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                                                <TextBlock Text="{DynamicResource CurrentSessionLabel}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding CreatedAtDisplay}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="11"
                                                   Margin="0,7,0,0" />
                                        <TextBlock Text="{Binding Metadata}"
                                                   Foreground="{StaticResource SubtleBrush}"
                                                   FontSize="11"
                                                   Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding RecordingWarning}"
                                                   Foreground="#EAA95E"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,6,0,0"
                                                   Visibility="{Binding HasRecordingWarning, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="{DynamicResource OpenSessionLabel}"
                                                Tag="{Binding}"
                                                IsEnabled="{Binding CanOpen}"
                                                MinWidth="88"
                                                Click="OpenSession_Click" />
                                        <Button Content="{DynamicResource DeleteSessionLabel}"
                                                Tag="{Binding}"
                                                IsEnabled="{Binding CanDelete}"
                                                Style="{StaticResource QuietButton}"
                                                Margin="8,0,0,0"
                                                Click="DeleteSession_Click" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="11"
                    Padding="34"
                    VerticalAlignment="Top"
                    Visibility="{Binding HasNoSessions, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                <StackPanel HorizontalAlignment="Center" MaxWidth="420" Margin="0,42,0,42">
                    <Border Width="54" Height="54" CornerRadius="27" Background="{StaticResource AccentSurfaceBrush}" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource AccentBrush}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{DynamicResource NoSessionsTitle}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,16,0,0" />
                    <TextBlock Text="{DynamicResource NoSessionsHint}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               LineHeight="19"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,7,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
